# =============================================================================
#  .env.example  —  committed template, NEVER put real secrets here.
#  Copy to `.env.local` (gitignored) and fill in the actual values.
#  All keys below are validated by `src/config/env.ts` (Zod) at startup.
# =============================================================================

# Database (Supabase Postgres connection — pooled URL on port 6543, must include sslmode=require)
DATABASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (set when AI module is wired up)
ANTHROPIC_API_KEY=

# Email (set when email module is wired up)
RESEND_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Runtime
NODE_ENV=development

# Seed script (npm run db:seed) — overrides only; defaults are admin@demo.local / DevPassword123!
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
